{
  "baseUrl": "https://www.arabam.com",
  "categories": {
    "otomobil": "/ikinci-el/otomobil"
  },
  "listPage": {
    "listingLinkSelector": "tr.listing-list-item a[href*=\"/ilan/\"]",
    "nextPageSelector": "a#pagingNext",
    "maxPagesPerCategory": 50
  },
  "detailPage": {
    "priceSelector": ".desktop-information-price",
    "propertiesTableSelector": ".property-item"
  },
  "blockedResourceTypes": ["image", "font", "media"],
  "blockedDomains": [
    "googlesyndication.com",
    "doubleclick.net",
    "google-analytics.com",
    "googletagmanager.com"
  ],
  "rateLimit": {
    "minDelayMs": 1500,
    "maxDelayMs": 4000
  },
  "retry": {
    "maxAttempts": 3,
    "backoffMs": 2000
  }
}

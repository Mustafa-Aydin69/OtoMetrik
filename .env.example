# Kafka
KAFKA_BROKER=localhost:9092
KAFKA_CLIENT_ID=otometrik
KAFKA_TOPIC_RAW_LISTINGS=raw-listings

# Proxy (arabam.com scraper icin)
# Rotasyonlu havuz (Webshare vb.) icin: "host1:port:user1:pass1,host2:port:user2:pass2,..."
# PROXY_LIST tanimliysa asagidaki tekil PROXY_* degiskenleri yok sayilir.
PROXY_LIST=

# PROXY_LIST tanimli degilse kullanilan tekil proxy (opsiyonel fallback)
# Ornek (Bright Data ISP formati): PROXY_HOST=brd.superproxy.io PROXY_PORT=33335
# PROXY_USERNAME=brd-customer-<musteri_id>-zone-<zone_adi> PROXY_PASSWORD=<sifre>
# Not: Webshare Static Residential ve Bright Data Turkey ISP ikisi de arabam.com'da Cloudflare
# 403'e takildi (bkz. proje notlari) - varsayilan olarak proxysiz (dogrudan baglanti) kullanilir.
PROXY_HOST=
PROXY_PORT=
PROXY_USERNAME=
PROXY_PASSWORD=

# Bright Data Scraping Browser (CDP) - duz proxy'lerin basaramadigi Cloudflare korumasini gecti.
# Ornek: wss://brd-customer-<musteri_id>-zone-<scraping_browser_zone_adi>:<sifre>@brd.superproxy.io:9222
BRIGHTDATA_SCRAPING_BROWSER_WS=
